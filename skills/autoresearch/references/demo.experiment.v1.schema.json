{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "demo.experiment.v1",
  "description": "One scored research experiment, identified by experiment_id.",
  "type": "object",
  "additionalProperties": true,
  "required": ["headline", "score"],
  "properties": {
    "experiment_id": {"type": "string"},
    "headline": {"type": "string"},
    "lane": {"type": "string"},
    "metric_name": {"type": "string"},
    "direction": {"type": "string", "enum": ["higher_better", "lower_better"]},
    "outcome": {"type": "string", "enum": ["worked", "regressed", "inconclusive"]},
    "score": {"type": "number"}
  }
}
